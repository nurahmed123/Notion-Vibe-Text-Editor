{
    "name": "notion-vibe-text-editor",
    "version": "1.0.2",
    "description": "A universal rich text editor with BlockNote and Mantine, supporting React, Next.js, Laravel, and Vanilla HTML.",
    "main": "./dist/notion-vibe-text-editor.umd.js",
    "module": "./dist/notion-vibe-text-editor.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/notion-vibe-text-editor.es.js",
            "require": "./dist/notion-vibe-text-editor.umd.js",
            "types": "./dist/index.d.ts"
        },
        "./style.css": "./dist/style.css"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nurahmed123/Notion-Vibe-Text-Editor.git"
    },
    "homepage": "https://github.com/nurahmed123/Notion-Vibe-Text-Editor#readme",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview"
    },
    "keywords": [
        "editor",
        "rich-text",
        "blocknote",
        "notion",
        "react",
        "vanilla"
    ],
    "author": "",
    "license": "MIT",
    "peerDependencies": {
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0"
    },
    "dependencies": {
        "@ai-sdk/openai-compatible": "^2.0.31",
        "@blocknote/code-block": "^0.46.2",
        "@blocknote/core": "^0.46.2",
        "@blocknote/mantine": "^0.46.2",
        "@blocknote/react": "^0.46.2",
        "@blocknote/xl-ai": "^0.46.2",
        "@mantine/core": "^8.3.11",
        "@mantine/hooks": "^8.3.11",
        "ai": "^4.0.0",
        "lucide-react": "^0.563.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "postcss": "^8.4.35",
        "tailwindcss": "3.4.1",
        "typescript": "^5.2.2",
        "vite": "^5.1.4",
        "vite-plugin-dts": "^3.7.3"
    }
}